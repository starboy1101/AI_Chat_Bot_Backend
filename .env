# # smaller model
# LLAMA_REPO=TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF
# LLAMA_FILENAME=tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf

# Legacy llama.cpp model settings. Disabled by default because chat now uses Ollama.
USE_LLAMA_CPP_BACKEND=false

# Faster/bigger model
LLAMA_REPO=Qwen/Qwen2.5-7B-Instruct-GGUF
LLAMA_FILENAME=qwen2.5-7b-instruct-q3_k_m.gguf

# Ollama model routing. Use the lightweight 3B model for local chat/extraction/SRS work.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EXTRACTOR_MODEL=qwen2.5:3b
OLLAMA_NUM_CTX=4096
OLLAMA_TIMEOUT_SECONDS=1800

LOCAL_AI_SRS_BASE_URL=http://localhost:11434
LOCAL_AI_SRS_TEXT_MODEL=qwen2.5:7b
LOCAL_AI_SRS_HELPER_MODEL=qwen2.5:7b
LOCAL_AI_SRS_TIMEOUT_SECONDS=1800
LOCAL_AI_SRS_NUM_CTX=4096
LOCAL_AI_SRS_MAX_CONTEXT_CHARS=8000
LOCAL_AI_SRS_RETRIEVAL_TOP_K=8
LOCAL_AI_SRS_BASELINE_MAX_CHARS=4000
LOCAL_AI_SRS_NUM_PREDICT=6000

# For Pdf extraction
PDF_EXTRACTOR_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
PDF_EXTRACTOR_FILENAME=qwen2.5-3b-instruct-q4_k_m.gguf
PDF_EXTRACTOR_CHAT_FORMAT=chatml
PDF_EXTRACTOR_N_CTX=4096
PDF_EXTRACTOR_N_BATCH=256
PDF_EXTRACTOR_N_GPU_LAYERS=0
PDF_PRELOAD_ON_STARTUP=true

PDF_QUESTION_BATCH_SIZE=14
PDF_EXTRACT_CHUNK_LEN=3500
PDF_EXTRACT_MAX_TOKENS=380
PDF_EXTRACT_JSON_RETRIES=1

LLM_CHAT_FORMAT=chatml
LLM_N_BATCH=128
LLM_N_GPU_LAYERS=0
LLM_WARMUP_ON_STARTUP=false
STREAM_CHAR_DELAY_SECONDS=0.007

MAX_CONTEXT_TOKENS=2024
CORS_ORIGINS=*
FLOW_FILE=questions.json

COLAB_SRS_BASE_URL=https://sensually-screen-recite.ngrok-free.dev
COLAB_SRS_ENDPOINT=/generate-srs
COLAB_SRS_MODEL=qwen2.5:7b
COLAB_SRS_API_KEY=shared-secret
COLAB_SRS_NUM_PREDICT=6000
COLAB_SRS_JSON_RETRIES=2
